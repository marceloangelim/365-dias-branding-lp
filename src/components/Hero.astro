---
---
<section id="hero" class="bg-brand-navy text-white overflow-hidden" aria-label="Apresentação do produto">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <div class="grid md:grid-cols-2 gap-12 items-center">

      <!-- Copy -->
      <div class="order-2 md:order-1">
        <!-- Badge -->
        <div class="badge bg-brand-cyan/20 text-brand-cyan mb-6 w-fit">
          <span>✦</span>
          Guia Prático · 365 Exercícios de Branding
        </div>

        <!-- Headline -->
        <h1 class="font-heading text-4xl sm:text-5xl xl:text-6xl font-extrabold leading-tight mb-6">
          Você tem o sonho de construir uma
          <span class="text-gradient"> marca apaixonante?</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-lg text-gray-300 mb-8 leading-relaxed max-w-lg">
          Aprenda a posicionar a sua marca digital e torná-la fascinante, com
          <strong class="text-white">365 exercícios práticos</strong> — um para cada dia do ano.
        </p>

        <!-- Stats rápidos -->
        <div class="flex flex-wrap gap-6 mb-8">
          <div class="text-center">
            <p class="font-heading font-extrabold text-2xl text-brand-cyan">
              <span class="count-up" data-target="50000">50000</span>+
            </p>
            <p class="text-xs text-gray-400 uppercase tracking-widest mt-1">Clientes</p>
          </div>
          <div class="w-px bg-white/10"></div>
          <div class="text-center">
            <p class="font-heading font-extrabold text-2xl text-brand-cyan">
              <span class="count-up" data-target="340000">340000</span>+
            </p>
            <p class="text-xs text-gray-400 uppercase tracking-widest mt-1">Seguidores</p>
          </div>
          <div class="w-px bg-white/10"></div>
          <div class="text-center">
            <p class="font-heading font-extrabold text-2xl text-brand-cyan">7 Dígitos</p>
            <p class="text-xs text-gray-400 uppercase tracking-widest mt-1">Faturamento</p>
          </div>
        </div>

        <!-- CTA principal -->
        <a
          href="#pricing"
          class="btn-shimmer inline-flex items-center gap-2 bg-brand-cyan text-brand-navy font-heading font-bold text-lg px-8 py-4 rounded-full shadow-lg shadow-brand-cyan/30 hover:shadow-brand-cyan/50 transition-all duration-300"
        >
          Quero ter uma marca encantadora!
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>

        <!-- Micro-copy -->
        <p class="text-sm text-gray-400 mt-4">
          Versão Digital a partir de <strong class="text-white">3x R$87,31</strong> · Acesso imediato
        </p>
      </div>

      <!-- Imagem do produto -->
      <div class="order-1 md:order-2 flex justify-center md:justify-end">
        <div id="hero-book" class="float-anim relative">
          <!-- Glow atrás do livro -->
          <div class="absolute -inset-8 bg-brand-cyan/20 rounded-full blur-3xl opacity-60 pointer-events-none"></div>
          <img
            src="/imgs/spiral_mockup_365_DB-1.gif"
            alt="Livro 365 Dias de Branding — Guia Prático com 365 exercícios de branding"
            width="460"
            height="520"
            loading="eager"
            fetchpriority="high"
            class="relative w-full max-w-xs sm:max-w-sm md:max-w-md drop-shadow-2xl"
          />
        </div>
      </div>

    </div>
  </div>

  <!-- Onda decorativa inferior -->
  <div class="relative h-16 overflow-hidden">
    <svg viewBox="0 0 1440 64" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="absolute bottom-0 w-full h-full">
      <path d="M0 32C240 64 480 0 720 32C960 64 1200 0 1440 32V64H0V32Z" fill="white"/>
    </svg>
  </div>
</section>
