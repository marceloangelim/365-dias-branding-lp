---
---
<section id="hero" class="bg-gradient-hero overflow-hidden" aria-label="Apresentação do produto">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 pt-6 sm:pt-10 pb-10">

    <div class="flex flex-col items-center text-center">

      <!-- Badge -->
      <div class="pill mb-3 sm:mb-5 gsap-reveal">
        <svg width="8" height="8" viewBox="0 0 10 10" fill="currentColor"><circle cx="5" cy="5" r="5"/></svg>
        <span class="sm:hidden">365 Exercícios de Branding</span>
        <span class="hidden sm:inline">Guia Prático · 365 Exercícios de Branding</span>
      </div>

      <!-- H1 -->
      <h1 class="font-heading font-extrabold text-3xl sm:text-5xl xl:text-[3.6rem] text-ink leading-[1.08] mb-2 sm:mb-4 tracking-tight max-w-3xl gsap-reveal">
        Construa uma<br />
        <span class="text-gradient">marca apaixonante</span><br />
        — um exercício por dia.
      </h1>

      <!-- Subtext -->
      <p class="text-ink-faint text-base sm:text-lg leading-relaxed mb-4 sm:mb-6 max-w-xl gsap-reveal">
        O guia prático com <strong class="text-ink font-semibold">365 exercícios de branding</strong> criado
        por Ellen, fundadora da Branding Lab — para empreendedoras que querem se posicionar e crescer de verdade.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4 mb-6 sm:mb-10 gsap-reveal">
        <a href="#pricing" class="btn-primary">
          Quero o 365DB agora
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <div class="text-left">
          <p class="text-xs text-ink-faint leading-tight">Digital a partir de</p>
          <p class="font-heading font-bold text-ink text-sm">3x R$87,31 · Acesso imediato</p>
        </div>
      </div>

      <!-- ── Book image — hero centerpiece ── -->
      <div class="relative w-full flex justify-center mb-6 sm:mb-10 gsap-reveal">
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="w-96 h-48 bg-accent/12 rounded-full blur-3xl"></div>
        </div>
        <div id="hero-book" class="float-anim book-open-anim relative z-10" style="animation-delay:0.2s">
          <img
            src="/imgs/spiral_mockup_365_DB-1.gif"
            alt="Livro 365 Dias de Branding — Guia Prático com 365 exercícios de branding"
            width="600" height="680"
            loading="eager"
            fetchpriority="high"
            class="w-full max-w-xs sm:max-w-md lg:max-w-lg h-auto object-contain drop-shadow-xl"
          />
        </div>
      </div>

      <!-- ── Stat cards ── -->
      <div class="grid grid-cols-3 gap-2 sm:gap-3 w-full max-w-lg gsap-reveal">

        <div class="stat-dark !p-3 sm:!p-6">
          <p class="font-heading font-extrabold text-base sm:text-2xl text-white leading-none">
            <span class="count-up" data-target="50000">50k</span>+
          </p>
          <p class="text-[9px] sm:text-xs text-gray-400 mt-1 uppercase tracking-widest">Clientes</p>
        </div>

        <div class="stat-dark !p-3 sm:!p-6">
          <p class="font-heading font-extrabold text-base sm:text-2xl text-white leading-none">
            <span class="count-up" data-target="340000">340k</span>+
          </p>
          <p class="text-[9px] sm:text-xs text-gray-400 mt-1 uppercase tracking-widest">Seguidores</p>
        </div>

        <div class="stat-cream !p-3 sm:!p-6">
          <p class="font-heading font-extrabold text-base sm:text-xl text-ink leading-none">7 Díg.</p>
          <div class="stars text-[10px] sm:text-xs mt-1">★★★★★</div>
        </div>

      </div>

    </div>
  </div>
</section>
