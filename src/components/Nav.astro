---
const navLinks = [
  { href: "#hero",        label: "A Promessa" },
  { href: "#o-guia",     label: "O Guia" },
  { href: "#conteudo",   label: "Conteúdo" },
  { href: "#por-dentro", label: "Por Dentro" },
  { href: "#a-autora",   label: "A Autora" },
  { href: "#resultados", label: "Resultados" },
  { href: "#bonus",      label: "Bônus" },
  { href: "#pricing",    label: "Investimento" },
  { href: "#duvidas",    label: "Dúvidas" },
];
---
<header id="nav" class="fixed top-4 left-0 right-0 z-50">
  <div
    id="nav-inner"
    class="mx-auto w-fit bg-white/90 backdrop-blur-md rounded-full px-3 py-2 flex items-center gap-2 shadow-sm border border-gray-100 transition-all duration-300 max-w-[calc(100vw-2rem)]"
  >
    <!-- Left group: composition image + text logo -->
    <a href="/" aria-label="Branding Lab" class="flex items-center gap-2 shrink-0">
      <img
        src="/imgs/nav-composition.webp"
        alt="Ellen e Branding Lab"
        width="80"
        height="40"
        class="h-9 w-auto rounded-full"
      />
      <img
        src="/imgs/logo-bl-text-navy.svg"
        alt="Branding Lab"
        width="100"
        height="24"
        class="h-5 w-auto hidden sm:block"
      />
    </a>

    <!-- Divider -->
    <div class="w-px h-5 bg-gray-200 mx-1 shrink-0"></div>

    <!-- Hamburger button -->
    <button
      id="nav-hamburger"
      aria-label="Menu de navegação"
      aria-expanded="false"
      aria-controls="nav-menu"
      class="flex flex-col items-center justify-center w-8 h-8 gap-[5px] rounded-full hover:bg-gray-100 transition-colors cursor-pointer shrink-0"
    >
      <span class="ham-line block w-4 h-0.5 bg-ink rounded-full transition-all duration-300 origin-center"></span>
      <span class="ham-line block w-4 h-0.5 bg-ink rounded-full transition-all duration-300"></span>
      <span class="ham-line block w-3 h-0.5 bg-ink rounded-full transition-all duration-300 origin-center"></span>
    </button>

    <!-- Right: CTA -->
    <a href="#pricing" class="btn-primary !py-2 !px-4 sm:!px-5 !text-sm cursor-pointer whitespace-nowrap shrink-0">
      Quero o 365DB
    </a>
  </div>
</header>

<!-- Dropdown menu -->
<div
  id="nav-menu"
  class="fixed top-[4.5rem] left-0 right-0 z-40 flex justify-center px-4 pointer-events-none opacity-0 -translate-y-2 transition-all duration-200"
  role="navigation"
  aria-label="Menu principal"
>
  <div class="bg-white/95 backdrop-blur-md rounded-2xl shadow-lg border border-gray-100 py-2 w-56">
    {navLinks.map(link => (
      <a
        href={link.href}
        class="nav-menu-link flex items-center gap-3 px-5 py-3 text-sm font-medium text-ink-muted hover:text-accent hover:bg-orange-50 transition-colors rounded-xl mx-1"
      >
        {link.label}
      </a>
    ))}
  </div>
</div>

<div class="h-20"></div>

<script>
  const navInner = document.getElementById('nav-inner');
  const hamburger = document.getElementById('nav-hamburger');
  const menu = document.getElementById('nav-menu');
  let menuOpen = false;

  // Scroll shadow
  window.addEventListener('scroll', () => {
    if (navInner) navInner.classList.toggle('shadow-md', window.scrollY > 40);
  }, { passive: true });

  function openMenu() {
    menuOpen = true;
    menu!.classList.remove('pointer-events-none', 'opacity-0', '-translate-y-2');
    menu!.classList.add('pointer-events-auto', 'opacity-100', 'translate-y-0');
    hamburger!.setAttribute('aria-expanded', 'true');
    const lines = hamburger!.querySelectorAll('.ham-line') as NodeListOf<HTMLElement>;
    lines[0].style.transform = 'translateY(5.5px) rotate(45deg)';
    lines[1].style.opacity = '0';
    lines[2].style.transform = 'translateY(-5.5px) rotate(-45deg)';
  }

  function closeMenu() {
    menuOpen = false;
    menu!.classList.add('pointer-events-none', 'opacity-0', '-translate-y-2');
    menu!.classList.remove('pointer-events-auto', 'opacity-100', 'translate-y-0');
    hamburger!.setAttribute('aria-expanded', 'false');
    const lines = hamburger!.querySelectorAll('.ham-line') as NodeListOf<HTMLElement>;
    lines[0].style.transform = '';
    lines[1].style.opacity = '';
    lines[2].style.transform = '';
  }

  hamburger?.addEventListener('click', () => menuOpen ? closeMenu() : openMenu());
  document.querySelectorAll('.nav-menu-link').forEach(l => l.addEventListener('click', closeMenu));
  document.addEventListener('click', (e) => {
    if (menuOpen && !hamburger!.contains(e.target as Node) && !menu!.contains(e.target as Node)) closeMenu();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && menuOpen) closeMenu(); });
</script>
