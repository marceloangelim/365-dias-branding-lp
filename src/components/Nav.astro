---
---
<header id="nav" class="fixed top-4 left-0 right-0 z-50 px-4">
  <div class="max-w-6xl mx-auto bg-white/90 backdrop-blur-md rounded-2xl px-5 h-14 flex items-center justify-between shadow-sm border border-gray-100 transition-all duration-300" id="nav-inner">
    <a href="/" aria-label="Branding Lab">
      <img src="/imgs/logo-branding-lab.svg" alt="Branding Lab" width="120" height="36" class="h-7 w-auto" />
    </a>
    <a href="#pricing" class="btn-primary !py-2 !px-5 !text-sm cursor-pointer">
      Quero o 365DB
    </a>
  </div>
</header>
<div class="h-20"></div>

<script>
  const navInner = document.getElementById('nav-inner');
  window.addEventListener('scroll', () => {
    if (navInner) {
      if (window.scrollY > 40) {
        navInner.classList.add('shadow-md');
      } else {
        navInner.classList.remove('shadow-md');
      }
    }
  }, { passive: true });
</script>
