<section class="bg-white py-10 border-y border-gray-100" aria-label="Empresas parceiras">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.15em] text-ink-faint mb-8">
      Ellen &amp; Branding Lab já trabalharam com
    </p>
    <div class="flex flex-wrap items-center justify-center gap-10">
      <img src="/imgs/logos/Febracis.svg"         alt="Febracis"     width="110" height="36" loading="lazy" class="h-7 w-auto opacity-30 hover:opacity-60 grayscale transition-opacity duration-300 cursor-default" />
      <img src="/imgs/logos/sebrae.svg"           alt="Sebrae"       width="110" height="36" loading="lazy" class="h-7 w-auto opacity-30 hover:opacity-60 grayscale transition-opacity duration-300 cursor-default" />
      <img src="/imgs/logos/rockC.svg"            alt="Rock Content" width="110" height="36" loading="lazy" class="h-7 w-auto opacity-30 hover:opacity-60 grayscale transition-opacity duration-300 cursor-default" />
      <img src="/imgs/logos/Godaddyy.svg"         alt="GoDaddy"      width="110" height="36" loading="lazy" class="h-7 w-auto opacity-30 hover:opacity-60 grayscale transition-opacity duration-300 cursor-default" />
      <img src="/imgs/logos/push.svg"             alt="Push"         width="70"  height="36" loading="lazy" class="h-6 w-auto opacity-30 hover:opacity-60 grayscale transition-opacity duration-300 cursor-default" />
      <img src="/imgs/logos/pague-menos-logo.svg" alt="Pague Menos"  width="110" height="36" loading="lazy" class="h-7 w-auto opacity-30 hover:opacity-60 grayscale transition-opacity duration-300 cursor-default" />
    </div>
  </div>
</section>
