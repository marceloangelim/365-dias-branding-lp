<section class="bg-white py-12 border-y border-surface-cream" aria-label="Empresas parceiras">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.15em] text-ink-faint mb-10">
      Ellen &amp; Branding Lab já trabalharam com
    </p>
    <div class="flex flex-wrap items-center justify-center gap-10">
      <img src="/imgs/logos/Febracis.svg"         alt="Febracis"     width="120" height="40" loading="lazy" class="h-8 w-auto opacity-35 hover:opacity-70 transition-opacity duration-300 grayscale cursor-pointer" />
      <img src="/imgs/logos/sebrae.svg"           alt="Sebrae"       width="120" height="40" loading="lazy" class="h-8 w-auto opacity-35 hover:opacity-70 transition-opacity duration-300 grayscale cursor-pointer" />
      <img src="/imgs/logos/rockC.svg"            alt="Rock Content" width="120" height="40" loading="lazy" class="h-8 w-auto opacity-35 hover:opacity-70 transition-opacity duration-300 grayscale cursor-pointer" />
      <img src="/imgs/logos/Godaddyy.svg"         alt="GoDaddy"      width="120" height="40" loading="lazy" class="h-8 w-auto opacity-35 hover:opacity-70 transition-opacity duration-300 grayscale cursor-pointer" />
      <img src="/imgs/logos/push.svg"             alt="Push"         width="80"  height="40" loading="lazy" class="h-7 w-auto opacity-35 hover:opacity-70 transition-opacity duration-300 grayscale cursor-pointer" />
      <img src="/imgs/logos/pague-menos-logo.svg" alt="Pague Menos"  width="120" height="40" loading="lazy" class="h-8 w-auto opacity-35 hover:opacity-70 transition-opacity duration-300 grayscale cursor-pointer" />
    </div>
  </div>
</section>
