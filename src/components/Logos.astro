    <p class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-8">
      Ellen &amp; Branding Lab já trabalharam com
    </p>

    <div class="flex flex-wrap items-center justify-center gap-10">
      <img src="/imgs/logos/Febracis.svg"           alt="Febracis"      width="120" height="40" loading="lazy" class="h-8 w-auto opacity-50 hover:opacity-100 transition-opacity grayscale hover:grayscale-0" />
      <img src="/imgs/logos/sebrae.svg"             alt="Sebrae"        width="120" height="40" loading="lazy" class="h-8 w-auto opacity-50 hover:opacity-100 transition-opacity grayscale hover:grayscale-0" />
      <img src="/imgs/logos/rockC.svg"              alt="Rock Content"  width="120" height="40" loading="lazy" class="h-8 w-auto opacity-50 hover:opacity-100 transition-opacity grayscale hover:grayscale-0" />
      <img src="/imgs/logos/Godaddyy.svg"           alt="GoDaddy"       width="120" height="40" loading="lazy" class="h-8 w-auto opacity-50 hover:opacity-100 transition-opacity grayscale hover:grayscale-0" />
