---
const whatsappLink = "https://brandinglab.com.br/whatsapp";
const emailContato = "contato@brandinglab.com.br";
---
<footer class="bg-brand-navy text-white/50 py-14" role="contentinfo">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">

      <!-- Logo + tagline -->
      <div class="text-center md:text-left">
        <a href="/" aria-label="Branding Lab — página inicial">
          <img
            src="/imgs/logo-branding-lab.svg"
            alt="Branding Lab"
            width="130"
            height="38"
            class="h-8 w-auto opacity-75 hover:opacity-100 transition-opacity mb-2"
          />
        </a>
        <p class="text-xs text-white/30">365 Dias de Branding · Branding Lab</p>
      </div>

      <!-- Links -->
      <nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm" aria-label="Links do rodapé">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="hover:text-brand-cyan transition-colors duration-200">
          Suporte WhatsApp
        </a>
        <a href={`mailto:${emailContato}`} class="hover:text-brand-cyan transition-colors duration-200">
          {emailContato}
        </a>
        <a href="#" class="hover:text-brand-cyan transition-colors duration-200">Política de Privacidade</a>
        <a href="https://brandinglab.com.br" target="_blank" rel="noopener noreferrer" class="hover:text-brand-cyan transition-colors duration-200">
          brandinglab.com.br
        </a>
      </nav>

    </div>

    <div class="border-t border-white/8 mt-10 pt-8 text-center text-xs text-white/25">
      <p>© {new Date().getFullYear()} Branding Lab — Todos os direitos reservados.</p>
      <p class="mt-1">365 Dias de Branding é uma marca registrada da Branding Lab.</p>
    </div>
  </div>
</footer>
