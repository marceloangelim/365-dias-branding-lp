---
const whatsappLink = "https://wa.me/55XXXXXXXXXX"; // <- substitua pelo seu número
---
<footer class="bg-brand-navy text-gray-400 py-12" role="contentinfo">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">

      <!-- Logo -->
      <a href="/" aria-label="Branding Lab — página inicial">
        <img
          src="/imgs/logo-branding-lab.svg"
          alt="Branding Lab"
          width="130"
          height="38"
          class="h-9 w-auto opacity-80 hover:opacity-100 transition-opacity"
        />
      </a>

      <!-- Links -->
      <nav class="flex flex-wrap items-center gap-6 text-sm" aria-label="Links do rodapé">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="hover:text-brand-cyan transition-colors">
          Suporte WhatsApp
        </a>
        <a href="#" class="hover:text-brand-cyan transition-colors">Política de Privacidade</a>
        <a href="https://brandinglab.com.br" target="_blank" rel="noopener noreferrer" class="hover:text-brand-cyan transition-colors">
          brandinglab.com.br
        </a>
      </nav>

    </div>

    <div class="border-t border-white/10 mt-8 pt-8 text-center text-xs text-gray-500">
      <p>© {new Date().getFullYear()} Branding Lab — Todos os direitos reservados.</p>
      <p class="mt-1">365 Dias de Branding é uma marca registrada da Branding Lab.</p>
    </div>
  </div>
</footer>
