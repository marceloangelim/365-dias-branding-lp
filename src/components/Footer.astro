---
const whatsappLink = "https://brandinglab.com.br/whatsapp";
const emailContato = "contato@brandinglab.com.br";
---
<footer class="bg-surface-warm border-t border-gray-100 text-ink-faint py-12" role="contentinfo">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="text-center md:text-left">
        <a href="/" aria-label="Branding Lab">
          <img src="/imgs/logo-branding-lab.svg" alt="Branding Lab" width="120" height="36" class="h-7 w-auto opacity-70 hover:opacity-100 transition-opacity" />
        </a>
        <p class="text-xs text-gray-400 mt-2">365 Dias de Branding · Branding Lab</p>
      </div>
      <nav class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm" aria-label="Links do rodapé">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors duration-200">Suporte WhatsApp</a>
        <a href={`mailto:${emailContato}`} class="hover:text-accent transition-colors duration-200">{emailContato}</a>
        <a href="#" class="hover:text-accent transition-colors duration-200">Política de Privacidade</a>
        <a href="https://brandinglab.com.br" target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors duration-200">brandinglab.com.br</a>
      </nav>
    </div>
    <div class="border-t border-gray-200 mt-10 pt-8 text-center text-xs text-gray-400">
      <p>© {new Date().getFullYear()} Branding Lab — Todos os direitos reservados.</p>
      <p class="mt-1">365 Dias de Branding é uma marca registrada da Branding Lab.</p>
    </div>
  </div>
</footer>
