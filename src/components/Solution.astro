---
const outcomes = [
  { num: "01", title: "365 ações práticas", desc: "Para criar ou gerir a sua marca todos os dias do ano — sem travar, sem ficar sem ideia." },
  { num: "02", title: "Clareza de posicionamento", desc: "Um guia completo para compartilhar estratégias com seu time e definir seu lugar no mercado." },
  { num: "03", title: "Passo a passo dos 365 dias", desc: "Ideal para quem está começando: cada dia do ano com uma ação de branding clara e executável." },
  { num: "04", title: "Liberdade de marca", desc: "Direcionamento real para posicionar sua marca no digital e construir um negócio lucrativo." },
];
---
<section class="bg-white py-24" aria-label="O que o 365DB entrega">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-16">
      <div class="pill mb-5 mx-auto w-fit">A solução</div>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-ink mb-4 gsap-reveal">
        O 365DB é o guia que vai<br />mudar isso
      </h2>
      <p class="text-ink-faint max-w-xl mx-auto leading-relaxed">
        Um <strong class="text-ink font-semibold">Guia Prático com 365 exercícios</strong> para todos os dias do ano,
        criado para empreendedoras que querem se posicionar e criar uma marca apaixonante.
      </p>
    </div>

    <!-- Numbered outcomes grid -->
    <div class="gsap-stagger-group grid sm:grid-cols-2 gap-6 mb-16">
      {outcomes.map((item) => (
        <div class="gsap-stagger-item group relative bg-surface-warm rounded-2xl p-8 border border-gray-100 card-lift overflow-hidden">
          <!-- Decorative number -->
          <span class="absolute -top-3 -right-2 font-heading font-extrabold text-8xl text-gray-100 leading-none pointer-events-none select-none group-hover:text-accent/10 transition-colors duration-300">
            {item.num}
          </span>
          <div class="relative">
            <div class="w-10 h-10 rounded-xl bg-accent-light flex items-center justify-center mb-5">
              <span class="font-heading font-bold text-sm text-accent">{item.num}</span>
            </div>
            <h3 class="font-heading font-bold text-xl text-ink mb-2">{item.title}</h3>
            <p class="text-ink-faint text-sm leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center gsap-reveal">
      <a href="#pricing" class="btn-primary">
        Sim, quero o Guia Prático 365DB!
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

  </div>
</section>
