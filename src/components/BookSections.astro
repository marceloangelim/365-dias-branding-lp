---
const sections = [
  {
    id: "fund", num: "01", title: "Fundamentos",
    color: "#E8572A",
    desc: "Mentalidade, direção e as principais preocupações na construção e gestão da sua marca.",
    pages: ["365sb-fund-01.avif","365sb-fund-02.avif","365sb-fund-03.avif","365sb-fund-04.avif","365sb-fund-05.avif"],
  },
  {
    id: "plan", num: "02", title: "Planejamento",
    color: "#C44820",
    desc: "Planeje detalhes inteligentes e defina os próximos passos com clareza e estratégia.",
    pages: ["365sb-plan-01.avif","365sb-plan-02.avif","365sb-plan-03.avif","365sb-plan-04.avif","365sb-plan-05.avif"],
  },
  {
    id: "exec", num: "03", title: "Execução",
    color: "#F4956A",
    desc: "O maior capítulo — atividades práticas para todos os 365 dias do ano.",
    pages: ["365sb-exec-01.avif","365sb-exec-02.avif","365sb-exec-03.avif","365sb-exec-04.avif","365sb-exec-05.avif"],
  },
];
---
<section class="bg-surface-warm py-24 overflow-hidden" aria-label="As 3 partes do livro">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-16">
      <div class="pill mb-5 mx-auto w-fit">Como é por dentro</div>
      <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-ink gsap-reveal">
        Material 100% prático em 3 partes
      </h2>
    </div>

    <!-- 3 section cards with large decorative numbers -->
    <div class="grid md:grid-cols-3 gap-6 mb-12 gsap-stagger-group">
      {sections.map((sec, i) => (
        <button
          data-section={sec.id}
          class={`book-tab gsap-stagger-item text-left rounded-2xl p-7 border-2 transition-all duration-300 cursor-pointer relative overflow-hidden ${i === 0 ? 'bg-white shadow-lg' : 'bg-white border-gray-100 hover:border-accent/30 hover:shadow-md'}`}
          style={i === 0 ? `border-color: ${sec.color}` : ''}
          aria-pressed={i === 0 ? 'true' : 'false'}
        >
          <!-- Deco number -->
          <span class="absolute -top-4 -right-3 font-heading font-extrabold text-8xl leading-none pointer-events-none select-none" style={`color: ${sec.color}15`}>{sec.num}</span>
          <div class="relative">
            <span class="font-heading font-bold text-xs uppercase tracking-widest block mb-3" style={`color: ${sec.color}`}>Parte {sec.num}</span>
            <span class="font-heading font-bold text-xl text-ink block mb-2">{sec.title}</span>
            <span class="text-xs text-ink-faint leading-relaxed block">{sec.desc}</span>
          </div>
        </button>
      ))}
    </div>

    <!-- Swiper -->
    <div class="swiper book-pages-swiper">
      <div class="swiper-wrapper py-4">
        {sections[0].pages.map((page, i) => (
          <div class="swiper-slide page-flip-wrap" style="width: 200px;">
            <img
              src={`/imgs/paginas-internas/${page}`}
              alt={`Página de Fundamentos ${i + 1}`}
              width="200" height="275"
              loading="lazy"
              class="gallery-img w-full h-auto rounded-xl cursor-zoom-in border border-gray-100"
            />
          </div>
        ))}
      </div>
      <div class="swiper-pagination mt-4"></div>
    </div>

  </div>
</section>

<script is:inline>
  const bookData = {
    fund: { color: '#E8572A', pages: ['365sb-fund-01.avif','365sb-fund-02.avif','365sb-fund-03.avif','365sb-fund-04.avif','365sb-fund-05.avif'], label: 'Fundamentos' },
    plan: { color: '#C44820', pages: ['365sb-plan-01.avif','365sb-plan-02.avif','365sb-plan-03.avif','365sb-plan-04.avif','365sb-plan-05.avif'], label: 'Planejamento' },
    exec: { color: '#F4956A', pages: ['365sb-exec-01.avif','365sb-exec-02.avif','365sb-exec-03.avif','365sb-exec-04.avif','365sb-exec-05.avif'], label: 'Execução' },
  };

  function initBookSwiper() {
    if (typeof Swiper === 'undefined') { setTimeout(initBookSwiper, 200); return; }
    const swiper = new Swiper('.book-pages-swiper', {
      slidesPerView: 'auto', spaceBetween: 14,
      grabCursor: true, loop: false,
      autoplay: { delay: 3000, disableOnInteraction: true }, speed: 500,
      pagination: { el: '.book-pages-swiper .swiper-pagination', clickable: true },
    });

    document.querySelectorAll('.book-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const sec = btn.dataset.section;
        const data = bookData[sec];
        document.querySelectorAll('.book-tab').forEach(b => {
          b.style.borderColor = '';
          b.classList.remove('shadow-lg', 'bg-white');
          b.classList.add('border-gray-100', 'bg-white');
          b.setAttribute('aria-pressed', 'false');
        });
        btn.style.borderColor = data.color;
        btn.classList.add('shadow-lg');
        btn.setAttribute('aria-pressed', 'true');

        swiper.removeAllSlides();
        swiper.appendSlide(data.pages.map((page, i) => `
          <div class="swiper-slide page-flip-wrap" style="width:200px">
            <img src="/imgs/paginas-internas/${page}" alt="Página de ${data.label} ${i+1}"
                 width="200" height="275" loading="lazy"
                 class="gallery-img w-full h-auto rounded-xl cursor-zoom-in border border-gray-100" />
          </div>`));
        swiper.slideTo(0, 0);

        document.querySelectorAll('.gallery-img').forEach(img => {
          img.onclick = () => {
            const lb = document.getElementById('lightbox');
            const lbImg = document.getElementById('lb-img');
            if (lb && lbImg) { lbImg.src = img.src; lbImg.alt = img.alt; lb.classList.add('show'); document.body.style.overflow = 'hidden'; }
          };
        });
      });
    });
  }
  window.addEventListener('load', initBookSwiper);
</script>
