---
const sections = [
  {
    id: "fund",
    num: "01", title: "Fundamentos",
    color: "#E8572A",
    description: "Mentalidade, direção e as principais preocupações na construção e gestão da sua marca.",
    pages: ["365sb-fund-01.avif","365sb-fund-02.avif","365sb-fund-03.avif","365sb-fund-04.avif","365sb-fund-05.avif"],
  },
  {
    id: "plan",
    num: "02", title: "Planejamento",
    color: "#C44820",
    description: "Planeje detalhes inteligentes e defina os próximos passos com clareza e estratégia.",
    pages: ["365sb-plan-01.avif","365sb-plan-02.avif","365sb-plan-03.avif","365sb-plan-04.avif","365sb-plan-05.avif"],
  },
  {
    id: "exec",
    num: "03", title: "Execução",
    color: "#F4956A",
    description: "O maior capítulo — atividades práticas para todos os 365 dias do ano.",
    pages: ["365sb-exec-01.avif","365sb-exec-02.avif","365sb-exec-03.avif","365sb-exec-04.avif","365sb-exec-05.avif"],
  },
];
---
<section class="bg-surface-warm py-20 overflow-hidden" aria-label="As 3 partes do livro">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-4">
      <span class="badge bg-accent-light text-accent">Como o 365DB é por dentro</span>
    </div>
    <h2 class="font-heading text-3xl sm:text-4xl font-extrabold text-brand-ink text-center mb-4 gsap-reveal">
      Material 100% prático em 3 partes
    </h2>
    <span class="ink-divider block mx-auto mb-12" style="max-width:100px"></span>

    <!-- Tabs de seção -->
    <div class="flex flex-col sm:flex-row gap-4 mb-10 justify-center" id="book-tabs">
      {sections.map((sec, i) => (
        <button
          data-section={sec.id}
          class={`book-tab flex-1 sm:max-w-[220px] text-left p-5 rounded-2xl border-2 transition-all duration-300 ${i === 0 ? 'border-accent bg-white shadow-md' : 'border-gray-200 bg-white/60 hover:border-accent/50'}`}
          style={i === 0 ? `border-color: ${sec.color}` : ''}
        >
          <span class="text-xs font-bold tracking-widest uppercase block mb-1" style={`color: ${sec.color}`}>Parte {sec.num}</span>
          <span class="font-heading font-extrabold text-lg text-brand-ink block mb-1">{sec.title}</span>
          <span class="text-xs text-gray-400 leading-snug">{sec.description}</span>
        </button>
      ))}
    </div>

    <!-- Swiper de páginas — atualizado por JS ao clicar nas tabs -->
    <div class="relative">
      <div class="swiper book-pages-swiper">
        <div class="swiper-wrapper" id="book-pages-wrapper">
          {/* Carrega Fundamentos por padrão */}
          {sections[0].pages.map((page, i) => (
            <div class="swiper-slide" style="width: 240px;">
              <img
                src={`/imgs/paginas-internas/${page}`}
                alt={`Página de Fundamentos ${i + 1}`}
                width="240" height="330"
                loading="lazy"
                class="gallery-img w-full h-auto rounded-2xl cursor-zoom-in border border-gray-100"
                data-section="fund"
              />
            </div>
          ))}
        </div>
        <div class="swiper-pagination mt-6"></div>
      </div>
    </div>

  </div>
</section>

<script is:inline>
  // Dados das seções para o JS
  const bookData = {
    fund: {
      color: '#E8572A',
      pages: ['365sb-fund-01.avif','365sb-fund-02.avif','365sb-fund-03.avif','365sb-fund-04.avif','365sb-fund-05.avif'],
      alts: ['Fundamentos','Fundamentos','Fundamentos','Fundamentos','Fundamentos'],
    },
    plan: {
      color: '#C44820',
      pages: ['365sb-plan-01.avif','365sb-plan-02.avif','365sb-plan-03.avif','365sb-plan-04.avif','365sb-plan-05.avif'],
      alts: ['Planejamento','Planejamento','Planejamento','Planejamento','Planejamento'],
    },
    exec: {
      color: '#F4956A',
      pages: ['365sb-exec-01.avif','365sb-exec-02.avif','365sb-exec-03.avif','365sb-exec-04.avif','365sb-exec-05.avif'],
      alts: ['Execução','Execução','Execução','Execução','Execução'],
    },
  };

  function initBookSwiper() {
    if (typeof Swiper === 'undefined') { setTimeout(initBookSwiper, 200); return; }

    const swiper = new Swiper('.book-pages-swiper', {
      slidesPerView: 'auto',
      spaceBetween: 16,
      centeredSlides: false,
      loop: false,
      grabCursor: true,
      autoplay: { delay: 3000, disableOnInteraction: true },
      speed: 500,
      pagination: { el: '.book-pages-swiper .swiper-pagination', clickable: true },
    });

    // Tabs
    document.querySelectorAll('.book-tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const sec = btn.dataset.section;
        const data = bookData[sec];

        // Atualiza estilos das tabs
        document.querySelectorAll('.book-tab').forEach(b => {
          b.style.borderColor = '';
          b.classList.remove('shadow-md');
          b.classList.add('border-gray-200');
          b.classList.remove('border-accent');
        });
        btn.style.borderColor = data.color;
        btn.classList.remove('border-gray-200');
        btn.classList.add('shadow-md');

        // Atualiza slides
        swiper.removeAllSlides();
        const slides = data.pages.map((page, i) => `
          <div class="swiper-slide" style="width:240px">
            <img src="/imgs/paginas-internas/${page}"
                 alt="Página de ${data.alts[i]} ${i + 1}"
                 width="240" height="330" loading="lazy"
                 class="gallery-img w-full h-auto rounded-2xl cursor-zoom-in border border-gray-100" />
          </div>`);
        swiper.appendSlide(slides);
        swiper.slideTo(0, 0);

        // Reatribui lightbox aos novos elementos
        document.querySelectorAll('.gallery-img').forEach(img => {
          img.onclick = () => {
            const lb = document.getElementById('lightbox');
            const lbImg = document.getElementById('lb-img');
            if (lb && lbImg) {
              lbImg.src = img.src;
              lbImg.alt = img.alt;
              lb.classList.add('show');
              document.body.style.overflow = 'hidden';
            }
          };
        });
      });
    });
  }

  window.addEventListener('load', initBookSwiper);
</script>
