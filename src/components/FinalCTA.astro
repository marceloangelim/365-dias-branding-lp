---
---
<section class="bg-accent py-28 relative overflow-hidden" aria-label="Chamada final">
  <!-- Book pages decorative lines -->
  <div class="absolute inset-0 pointer-events-none opacity-10">
    {Array.from({length: 12}).map((_, i) => (
      <div class="absolute left-0 right-0 h-px bg-white" style={`top: ${8 + i * 7.5}%;`}></div>
    ))}
  </div>

  <!-- Spiral rings decorative (top-right) -->
  <div class="absolute -top-20 -right-20 w-72 h-72 border-4 border-white/10 rounded-full pointer-events-none"></div>
  <div class="absolute -top-10 -right-10 w-40 h-40 border-2 border-white/15 rounded-full pointer-events-none"></div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
    <div class="gsap-reveal">
      <p class="text-white/70 text-sm font-semibold uppercase tracking-widest mb-5">Comece hoje</p>

      <h2 class="font-heading font-extrabold text-4xl sm:text-6xl text-white leading-[1.05] mb-6">
        1 exercício para<br />cada dia do ano<br />na sua marca.
      </h2>

      <p class="text-white/80 text-lg leading-relaxed mb-10 max-w-xl mx-auto">
        O 365 Dias de Branding é seu companheiro de execução — prático, real, e feito
        para transformar a sua marca todos os dias do ano.
      </p>

      <!-- Stars -->
      <div class="flex items-center justify-center gap-2 mb-8">
        <span class="stars text-xl text-white">★★★★★</span>
        <span class="text-white/70 text-sm">+50.000 empreendedoras transformadas</span>
      </div>

      <a href="#pricing" class="btn-white">
        Sim, quero o Guia Prático 365DB!
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>

      <p class="text-white/60 text-sm mt-5">
        Digital a partir de <strong class="text-white/90">3x R$87,31</strong> · Acesso imediato
      </p>
    </div>
  </div>
</section>
