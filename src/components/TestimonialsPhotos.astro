  { file: "Depoimento_365_Foto1004.webp",           alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1008.webp",           alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1010-768x954.webp",   alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1013-768x1118.webp",  alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1014-768x1058.webp",  alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1014b-768x1058.webp", alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1015-768x944.webp",   alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1017-768x1290.webp",  alt: "Cliente com o livro 365 Dias de Branding" },
  { file: "Depoimento_365_Foto1018-768x1072.webp",  alt: "Cliente com o livro 365 Dias de Branding" },
