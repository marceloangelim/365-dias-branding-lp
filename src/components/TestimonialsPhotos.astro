  { file: "cliente_stories_1.webp",                 alt: "Story de cliente com o 365 Dias de Branding" },
  { file: "cliente_stories_2.webp",                 alt: "Story de cliente com o 365 Dias de Branding" },
  { file: "cliente_stories_3.webp",                 alt: "Story de cliente com o 365 Dias de Branding" },
  { file: "cliente_stories_4.webp",                 alt: "Story de cliente com o 365 Dias de Branding" },
