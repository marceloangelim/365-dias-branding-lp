---
const pages = [
  "365sb-fund-01.avif","365sb-fund-02.avif","365sb-fund-03.avif","365sb-fund-04.avif","365sb-fund-05.avif",
  "365sb-plan-01.avif","365sb-plan-02.avif","365sb-plan-03.avif","365sb-plan-04.avif","365sb-plan-05.avif",
  "365sb-exec-01.avif","365sb-exec-02.avif","365sb-exec-03.avif","365sb-exec-04.avif","365sb-exec-05.avif",
];
---
<section class="bg-white py-24 overflow-hidden" aria-label="Páginas do livro 365 Dias de Branding">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <div class="chapter-badge justify-center mb-4">Conteúdo real</div>
      <h2 class="font-heading text-3xl sm:text-4xl font-bold text-ink gsap-reveal">
        Veja por dentro
      </h2>
      <p class="text-ink-faint mt-3 text-sm">Clique em qualquer página para ampliar.</p>
    </div>
  </div>

  <!-- Swiper 3D Coverflow full-bleed -->
  <div class="swiper gallery-swiper px-4">
    <div class="swiper-wrapper py-6">
      {pages.map((page, i) => (
        <div class="swiper-slide rounded-2xl overflow-hidden" style="width:210px">
          <img
            src={`/imgs/paginas-internas/${page}`}
            alt={`Página interna do livro 365 Dias de Branding — ${i + 1}`}
            width="210" height="290"
            loading="lazy"
            class="gallery-img w-full h-auto cursor-zoom-in"
          />
        </div>
      ))}
    </div>
    <div class="swiper-pagination mt-4"></div>
  </div>
</section>

<script is:inline>
  function initGallerySwiper() {
    if (typeof Swiper === 'undefined') { setTimeout(initGallerySwiper, 200); return; }
    new Swiper('.gallery-swiper', {
      effect: 'coverflow',
      grabCursor: true,
      centeredSlides: true,
      slidesPerView: 'auto',
      loop: true,
      autoplay: { delay: 2800, disableOnInteraction: false, pauseOnMouseEnter: true },
      speed: 700,
      coverflowEffect: {
        rotate: 22,
        stretch: 8,
        depth: 110,
        modifier: 1,
        slideShadows: false,
      },
      pagination: { el: '.gallery-swiper .swiper-pagination', clickable: true },
    });
  }
  window.addEventListener('load', initGallerySwiper);
</script>
