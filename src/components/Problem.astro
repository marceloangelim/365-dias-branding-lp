---
const profiles = [
  {
    id: 'inicio',
    title: 'Empreendedora em início',
    desc: 'Está criando sua marca e não sabe por onde começar. Precisa de um caminho claro — dia a dia — para construir algo sólido do zero.',
    img: '/imgs/empresarias-branding-lab.avif',
  },
  {
    id: 'servicos',
    title: 'Prestadora de serviços',
    desc: 'Já tem uma marca mas está estagnada. Quer novas estratégias para alavancar seu posicionamento, aumentar sua autoridade e vender mais.',
    img: '/imgs/empresarias-branding-lab.avif',
  },
  {
    id: 'info',
    title: 'Infoprodutora / Social Media',
    desc: 'Profissional de marketing que precisa de novas ideias, referências e ações práticas para apresentar a clientes — todos os dias do ano.',
    img: '/imgs/empresarias-branding-lab.avif',
  },
  {
    id: 'mentora',
    title: 'Consultora ou Mentora',
    desc: 'Atende empreendedoras e precisa de novas ações e exercícios de branding para enriquecer suas consultorias e mentorias.',
    img: '/imgs/empresarias-branding-lab.avif',
  },
];
---
<section class="bg-surface-warm py-24" aria-label="Para quem é o 365 Dias de Branding">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="grid md:grid-cols-[1fr_1fr] gap-16 items-start">

      <!-- LEFT: heading + accordion -->
      <div>
        <div class="pill mb-5">Este guia é para você que…</div>
        <h2 class="font-heading font-extrabold text-3xl sm:text-4xl text-ink mb-3 leading-tight gsap-reveal">
          Você já se sentiu<br />
          <span class="underline-accent gsap-underline">perdida ao criar sua marca?</span>
        </h2>
        <p class="text-ink-faint mb-10 leading-relaxed">Se você se identificar com qualquer um desses perfis, o 365DB foi criado exatamente para você.</p>

        <!-- Accordion -->
        <div id="prob-list" class="space-y-0">
          {profiles.map((p, i) => (
            <div class={`prob-item ${i === 0 ? 'active' : ''}`} data-img={p.img} data-index={i}>
              <button class="w-full flex items-center justify-between gap-4 py-5 pr-1 text-left cursor-pointer" aria-expanded={i === 0 ? 'true' : 'false'}>
                <div class="flex items-center gap-4">
                  <span class="flex-shrink-0 w-8 h-8 rounded-full bg-accent-light text-accent font-heading font-bold text-sm flex items-center justify-center">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <span class="font-heading font-bold text-ink text-base">{p.title}</span>
                </div>
                <span class="prob-icon flex-shrink-0 text-accent text-2xl font-light leading-none">+</span>
              </button>
              <div class="prob-body">
                <p class="text-ink-faint text-sm leading-relaxed pb-5 pl-12">{p.desc}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Pull quote -->
        <div class="mt-10 pl-5 border-l-4 border-accent gsap-reveal">
          <p class="text-ink-muted italic leading-relaxed mb-2">
            "Quando decidi empreender eu tinha muitas ideias, mas ao mesmo tempo sentia muita
            <strong class="text-ink not-italic font-semibold">solidão</strong> e falta de uma direção…"
          </p>
          <cite class="not-italic text-xs text-accent font-bold uppercase tracking-widest">— Ellen, fundadora da Branding Lab</cite>
        </div>
      </div>

      <!-- RIGHT: Photo (swaps with accordion) -->
      <div class="hidden md:block sticky top-28 gsap-reveal-right">
        <div class="relative rounded-3xl overflow-hidden">
          <img
            id="prob-photo"
            src="/imgs/empresarias-branding-lab.avif"
            alt="Empreendedoras da Branding Lab"
            width="540" height="600"
            loading="lazy"
            class="w-full object-cover rounded-3xl shadow-xl transition-opacity duration-300"
            style="aspect-ratio: 9/10;"
          />
          <!-- Floating credibility badge -->
          <div class="absolute bottom-6 left-6 right-6 bg-white/95 backdrop-blur-sm rounded-2xl p-4 shadow-lg">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0">
                <img src="/imgs/depoimentos/ellen-365-v3.avif" alt="Ellen" width="40" height="40" loading="lazy" class="w-full h-full object-cover" />
              </div>
              <div>
                <p class="font-heading font-bold text-ink text-sm">Ellen · Branding Lab</p>
                <p class="text-xs text-ink-faint">8 anos de branding · 50k clientes</p>
              </div>
              <div class="ml-auto">
                <div class="stars text-xs">★★★★★</div>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<script is:inline>
  const items = document.querySelectorAll('.prob-item');
  const photo = document.getElementById('prob-photo');

  items.forEach(item => {
    item.querySelector('button').addEventListener('click', () => {
      // Close all
      items.forEach(i => {
        i.classList.remove('active');
        i.querySelector('button').setAttribute('aria-expanded', 'false');
      });
      // Open clicked
      item.classList.add('active');
      item.querySelector('button').setAttribute('aria-expanded', 'true');
      // Swap photo
      if (photo && item.dataset.img) {
        photo.style.opacity = '0';
        setTimeout(() => {
          photo.src = item.dataset.img;
          photo.style.opacity = '1';
        }, 200);
      }
    });
  });
</script>
